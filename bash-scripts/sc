#!/bin/bash

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ACTION_FILE=$(mktemp)

while true; do
    echo "run" > "$ACTION_FILE"

    file=$(find "$BASE_DIR" -type f -name "*.sh" | \
        awk -F/ '{print $NF "\t" $0}' | sort -t$'\t' -k1 | \
        fzf --prompt="Script: " \
            --with-nth=1 \
            --delimiter='\t' \
            --preview='bat --color=always {2} 2>/dev/null || cat {2}' \
            --header="Enter: run | ctrl+x: delete | ctrl+r: rename | esc: exit" \
            --bind "ctrl-x:execute-silent(echo del > $ACTION_FILE)+accept" \
            --bind "ctrl-r:execute-silent(echo ren > $ACTION_FILE)+accept" | cut -f2)

    action=$(cat "$ACTION_FILE")

    [ -z "$file" ] && break

    if [[ "$action" == "del" ]]; then
        filename=$(basename "$file")
        read -p "Search for usages of '$filename' before deleting? [y/N] " search_confirm
        if [[ "$search_confirm" =~ ^[Yy]$ ]]; then
            echo "Searching..."
            pattern="/${filename//./\\.}"
            usages=$(ack -rl "$pattern" "$HOME/dotfiles" 2>/dev/null | grep -v "^$file$")
            if [[ -n "$usages" ]]; then
                echo "WARNING: '$filename' is referenced in:"
                echo "$usages" | sed 's/^/  /'
            else
                echo "No usages found."
            fi
            echo ""
        fi
        read -p "Delete $filename? [y/N] " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] && rm "$file" && echo "Removed: $file"
        continue
    elif [[ "$action" == "ren" ]]; then
        read -p "Rename $(basename "$file") to: " newname
        if [[ -n "$newname" ]]; then
            mv "$file" "$(dirname "$file")/$newname" && echo "Renamed to: $newname"
        fi
        continue
    else
        bash "$file"
        break
    fi
done

rm -f "$ACTION_FILE"
